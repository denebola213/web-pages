{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug post_mastodon.ts",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/post_mastodon.ts",
      "runtimeExecutable": "/usr/bin/deno",
      "runtimeArgs": [
        "run",
        "--inspect-wait",
        "--allow-env",
        "--allow-read",
        "--allow-net",
        "--allow-run"
      ],
      "env": {
        "DENO_ENV": "development"
      },
      "cwd": "${workspaceFolder}/scripts",
      "attachSimplePort": 9229
    }
  ]
}
